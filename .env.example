DB_HOST=your-db-host.region.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=change-me
DB_NAME=rma_app
FLASK_SECRET_KEY=generate-with-python-secrets-token_urlsafe-48
ADMIN_PASSWORD=pick-a-strong-password
APP_BASE_URL=http://localhost:5000

# --- Server / runtime ---
# Debug mode exposes the Werkzeug debugger (remote code execution). Keep OFF in prod.
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# Set to 1 in production (HTTPS). Set to 0 only for local HTTP development.
SESSION_COOKIE_SECURE=1
